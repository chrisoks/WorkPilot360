generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id               String              @id @default(cuid())
  name             String
  slug             String              @unique
  locale           String              @default("de")
  timezone         String              @default("Europe/Berlin")
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  auditLogs        AuditLog[]
  businessAreas    BusinessArea[]
  businessAreaTargets BusinessAreaTarget[]
  categories       Category[]
  departments      Department[]
  escalationRules  EscalationRule[]
  notifications    Notification[]
  catalogItems     CatalogItem[]
  catalogItemHistory CatalogItemHistory[]
  unitOptions      UnitOption[]
  catalogPackageItems CatalogPackageItem[]
  contentApprovalHistory ContentApprovalHistory[]
  contentItems     ContentItem[]
  offers           Offer[]
  offerLines       OfferLine[]
  offerLineLabor   OfferLineLabor[]
  offerHistory     OfferHistory[]
  invoices         Invoice[]
  invoiceLines     InvoiceLine[]
  invoiceLineLabor InvoiceLineLabor[]
  invoiceHistory   InvoiceHistory[]
  employeeCostCalculations EmployeeCostCalculation[]
  recurringRules   RecurringTaskRule[]
  subcategories    Subcategory[]
  tasks            Task[]
  taskComments     TaskComment[]
  taskLinks        TaskLink[]
  taskParticipants TaskParticipant[]
  taskTemplates    TaskTemplate[]
  teams            Team[]
  timeEntries      TimeEntry[]
  users            User[]
}

model User {
  id                  String            @id @default(cuid())
  organizationId      String
  email               String
  passwordHash        String
  firstName           String
  lastName            String
  role                Role
  isActive            Boolean           @default(true)
  teamId              String?
  departmentId        String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  dailyWorkHours      Float             @default(8)
  profileImageDataUrl String?
  salutation          String?
  birthDate           DateTime?
  language            String?
  phone               String?
  mobile              String?
  street              String?
  postalCode          String?
  city                String?
  signature           String?
  signatureHidden     Boolean?          @default(false)
  planningBoard       String?
  planningGroup       String?
  weeklyCapacity      Json              @default("{\"monday\":8,\"tuesday\":8,\"wednesday\":8,\"thursday\":8,\"friday\":8,\"saturday\":0,\"sunday\":0}")
  planningStartTime   String            @default("08:00")
  planningEndTime     String            @default("17:00")
  planningTimeWindows Json              @default("{\"monday\":{\"start\":\"08:00\",\"end\":\"17:00\"},\"tuesday\":{\"start\":\"08:00\",\"end\":\"17:00\"},\"wednesday\":{\"start\":\"08:00\",\"end\":\"17:00\"},\"thursday\":{\"start\":\"08:00\",\"end\":\"17:00\"},\"friday\":{\"start\":\"08:00\",\"end\":\"17:00\"},\"saturday\":{\"start\":\"08:00\",\"end\":\"17:00\"},\"sunday\":{\"start\":\"08:00\",\"end\":\"17:00\"}}")
  planningBreakWindows Json             @default("{\"monday\":{\"start\":\"12:00\",\"end\":\"12:30\"},\"tuesday\":{\"start\":\"12:00\",\"end\":\"12:30\"},\"wednesday\":{\"start\":\"12:00\",\"end\":\"12:30\"},\"thursday\":{\"start\":\"12:00\",\"end\":\"12:30\"},\"friday\":{\"start\":\"12:00\",\"end\":\"12:30\"},\"saturday\":{\"start\":\"\",\"end\":\"\"},\"sunday\":{\"start\":\"\",\"end\":\"\"}}")
  planningResponsibleFor Json           @default("[]")
  branchAllocations Json?
  includeInLaborCostRate Boolean        @default(true)
  notifyIdeaStore    Boolean           @default(true)
  notifyUpsell       Boolean           @default(false)
  mailAccount        Json              @default("{}")
  employeeAssessment Json              @default("{}")
  costCalculations  EmployeeCostCalculation[]
  notifications       Notification[]
  ownedTasks          Task[]            @relation("TaskOwner")
  taskComments        TaskComment[]
  taskParticipations  TaskParticipant[]
  timeEntries         TimeEntry[]
  department          Department?       @relation(fields: [departmentId], references: [id])
  organization        Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team                Team?             @relation(fields: [teamId], references: [id])

  @@unique([organizationId, email])
}

model EmployeeCostCalculation {
  id                 String       @id @default(cuid())
  organizationId     String
  userId             String
  monthlySalary      Float        @default(0)
  fullCostFactor     Float        @default(1.35)
  annualHours        Float        @default(2080)
  vacationDays       Float        @default(30)
  trainingDays       Float        @default(0)
  sickDays           Float        @default(10)
  hoursPerDay        Float        @default(8)
  updatedByUserId    String?
  updatedByName      String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId, userId])
}

model Department {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  teams          Team[]
  users          User[]
}

model Team {
  id             String       @id @default(cuid())
  organizationId String
  departmentId   String?
  name           String
  tasks          Task[]
  department     Department?  @relation(fields: [departmentId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users          User[]
}

model Task {
  id                      String                  @id @default(cuid())
  organizationId          String
  title                   String
  description             String
  status                  TaskStatus              @default(OFFEN)
  priority                TaskPriority            @default(NORMAL)
  deadline                DateTime
  customer                String?
  customerClass           CustomerClassification?
  projectId               String?
  categoryId              String?
  subcategoryId           String?
  estimateMinutes         Int?
  ownerId                 String
  teamId                  String?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  autoFeedbackEnabled     Boolean                 @default(false)
  autoFeedbackRecipientId String?
  recurrenceEnabled       Boolean                 @default(false)
  recurrenceInterval      String?
  recurrenceParentTaskId  String?
  createdById             String?
  acceptanceStatus        String                  @default("accepted")
  acceptanceRespondedAt   DateTime?
  rejectionReason         String?
  completedAt             DateTime?
  archiveDueAt            DateTime?
  archivedAt              DateTime?
  archiveReason           String?
  planningAllocations     Json                    @default("[]")
  history                 Json                    @default("[]")
  auditLogs               AuditLog[]
  notifications           Notification[]
  category                Category?               @relation(fields: [categoryId], references: [id])
  organization            Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner                   User                    @relation("TaskOwner", fields: [ownerId], references: [id])
  subcategory             Subcategory?            @relation(fields: [subcategoryId], references: [id])
  team                    Team?                   @relation(fields: [teamId], references: [id])
  comments                TaskComment[]
  links                   TaskLink[]
  participants            TaskParticipant[]
  timeEntries             TimeEntry[]

  @@index([organizationId, projectId])
}

model TaskParticipant {
  id                    String       @id @default(cuid())
  organizationId        String
  taskId                String
  userId                String
  acceptanceStatus      String       @default("pending")
  acceptanceRespondedAt DateTime?
  rejectionReason       String?
  createdAt             DateTime     @default(now())
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  task                  Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user                  User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
}

model TaskComment {
  id             String       @id @default(cuid())
  organizationId String
  taskId         String
  authorId       String
  recipientUserId String?
  body           String
  createdAt      DateTime     @default(now())
  author         User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  task           Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model TimeEntry {
  id              String       @id @default(cuid())
  organizationId  String
  taskId          String
  userId          String
  startedAt       DateTime
  stoppedAt       DateTime?
  durationMinutes Int          @default(0)
  note            String?
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  task            Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TaskLink {
  id             String       @id @default(cuid())
  organizationId String
  taskId         String
  label          String
  url            String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  task           Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Category {
  id             String        @id @default(cuid())
  organizationId String
  businessAreaId String?
  name           String
  projectPrefix  String?
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  businessArea   BusinessArea? @relation(fields: [businessAreaId], references: [id], onDelete: SetNull)
  subcategories  Subcategory[]
  tasks          Task[]

  @@index([organizationId, businessAreaId])
}

model BusinessArea {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  categories     Category[]
  targets        BusinessAreaTarget[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model BusinessAreaTarget {
  id             String       @id @default(cuid())
  organizationId String
  businessAreaId String
  month          String
  amount         Float        @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  businessArea   BusinessArea @relation(fields: [businessAreaId], references: [id], onDelete: Cascade)

  @@unique([organizationId, businessAreaId, month])
  @@index([organizationId, month])
}

model Subcategory {
  id             String       @id @default(cuid())
  organizationId String
  categoryId     String
  name           String
  category       Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tasks          Task[]
}

model Notification {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  taskId         String?
  channel        String
  subject        String
  body           String
  linkTarget     String?
  linkTargetId   String?
  linkLabel      String?
  sentAt         DateTime?
  createdAt      DateTime     @default(now())
  readAt         DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  task           Task?        @relation(fields: [taskId], references: [id])
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CatalogItem {
  id                    String               @id @default(cuid())
  organizationId        String
  type                  String               @default("article")
  number                String
  name                  String
  category              String?
  unit                  String               @default("Stk")
  description           String?
  matchcode             String?
  ean                   String?
  costCenter            String?
  supplierName          String?
  supplierNumber        String?
  manufacturer          String?
  manufacturerNumber    String?
  manufacturerTypeName  String?
  minimumOrderQuantity  Float?
  quantityScale         String?
  priceUnit             String?
  deliveryTime          String?
  stockQuantity         Float?
  purchasePrice         Float                @default(0)
  laborCostRateKey      String               @default("")
  listPrice             Float                @default(0)
  salesPrice            Float                @default(0)
  vatRate               Float                @default(19)
  isPlanningRelevant    Boolean              @default(false)
  planningMinutesPerUnit Int                 @default(0)
  defaultPlanningBoard  String?
  defaultPlanningGroup  String?
  isActive              Boolean              @default(true)
  usedCount             Int                  @default(0)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  organization          Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  history               CatalogItemHistory[]
  packageItems          CatalogPackageItem[] @relation("CatalogPackage")
  usedInPackages        CatalogPackageItem[] @relation("CatalogPackageComponent")

  @@unique([organizationId, number])
  @@index([organizationId, type])
  @@index([organizationId, isActive])
}

model CatalogPackageItem {
  id                  String       @id @default(cuid())
  organizationId      String
  packageId           String
  componentItemId     String
  quantity            Float        @default(1)
  position            Int          @default(0)
  descriptionOverride String?
  priceOverride       Float?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  package             CatalogItem  @relation("CatalogPackage", fields: [packageId], references: [id], onDelete: Cascade)
  componentItem        CatalogItem  @relation("CatalogPackageComponent", fields: [componentItemId], references: [id], onDelete: Restrict)

  @@index([organizationId, packageId])
  @@index([organizationId, componentItemId])
}

model CatalogItemHistory {
  id             String       @id @default(cuid())
  organizationId String
  catalogItemId  String
  eventType      String
  fieldName      String?
  oldValue       String?
  newValue       String?
  actorUserId    String?
  actorName      String?
  note           String?
  createdAt      DateTime     @default(now())
  catalogItem    CatalogItem  @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, catalogItemId])
  @@index([organizationId, createdAt])
}

model UnitOption {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  sortOrder      Int          @default(0)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId, isActive, sortOrder])
}

model ContentItem {
  id                    String                   @id @default(cuid())
  organizationId        String
  title                 String
  description           String                   @default("")
  channel               String                   @default("Instagram")
  format                String                   @default("Post")
  ownerUserId           String?
  ownerName             String                   @default("")
  plannedDate           String
  productionDueDate     String                   @default("")
  productionDueTime     String                   @default("17:00")
  approvalDueDate       String                   @default("")
  approvalDueTime       String                   @default("17:00")
  plannedTime           String                   @default("09:00")
  approvalLevel         String                   @default("gruen")
  status                String                   @default("Idee")
  directionApprovedById String?
  directionApprovedByName String?
  directionApprovedAt   DateTime?
  finalApprovedById     String?
  finalApprovedByName   String?
  finalApprovedAt       DateTime?
  correctionNote        String                   @default("")
  assetLink             String                   @default("")
  imageDataUrl          String                   @default("")
  sourceIdeaId          String?
  sourceIdeaTitle       String                   @default("")
  createdByUserId       String?
  createdByName         String                   @default("")
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  organization          Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  history               ContentApprovalHistory[]

  @@index([organizationId, plannedDate])
  @@index([organizationId, status])
  @@index([organizationId, approvalLevel])
}

model ContentApprovalHistory {
  id             String       @id @default(cuid())
  organizationId String
  contentItemId  String
  eventType      String
  fromStatus     String?
  toStatus       String?
  actorUserId    String?
  actorName      String       @default("")
  note           String       @default("")
  createdAt      DateTime     @default(now())
  contentItem    ContentItem  @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, contentItemId])
  @@index([organizationId, createdAt])
}

model Offer {
  id                  String       @id @default(cuid())
  organizationId      String
  projectId           String
  projectNumber       String       @default("")
  projectTitle        String       @default("")
  company             String       @default("OK solutions")
  offerType           String       @default("base")
  addendumMode        String       @default("addition")
  plannedExecutionEndMonth String   @default("")
  parentOfferId       String       @default("")
  offerNumber         String
  status              String       @default("Entwurf")
  customerName        String       @default("")
  customerStreet      String       @default("")
  customerCity        String       @default("")
  contactName         String       @default("")
  internalContactName String       @default("")
  internalPhone       String       @default("")
  internalEmail       String       @default("")
  plannedExecutionMonth String     @default("")
  introText           String       @default("")
  closingText         String       @default("")
  netTotal            Float        @default(0)
  vatRate             Float        @default(19)
  grossTotal          Float        @default(0)
  discountPercent     Float        @default(0)
  pdfData             String?      @db.Text
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lines               OfferLine[]

  @@unique([organizationId, offerNumber])
  @@index([organizationId, projectId])
}

model OfferLine {
  id             String       @id @default(cuid())
  organizationId String
  offerId        String
  catalogItemId  String       @default("")
  catalogType    String       @default("")
  position       Int          @default(0)
  quantity       Float        @default(1)
  unit           String       @default("Stk")
  title          String       @default("")
  description    String      @default("")
  unitPrice      Float        @default(0)
  discountPercent Float       @default(0)
  laborCostRateKey String     @default("")
  laborCostRate  Float        @default(0)
  vatRate        Float        @default(19)
  totalNet       Float        @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  offer          Offer        @relation(fields: [offerId], references: [id], onDelete: Cascade)
  laborItems     OfferLineLabor[]

  @@index([organizationId, offerId])
}

model OfferLineLabor {
  id             String       @id @default(cuid())
  organizationId String
  offerId        String
  offerLineId    String
  userId         String       @default("")
  employeeName   String       @default("")
  plannedHours   Float        @default(0)
  hourlyCostRate Float        @default(0)
  totalCost      Float        @default(0)
  position       Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  offerLine      OfferLine    @relation(fields: [offerLineId], references: [id], onDelete: Cascade)

  @@index([organizationId, offerId])
  @@index([organizationId, offerLineId])
  @@index([organizationId, userId])
}

model OfferHistory {
  id             String       @id @default(cuid())
  organizationId String
  offerId        String
  projectId      String
  offerNumber    String       @default("")
  eventType      String       @default("")
  title          String       @default("")
  note           String       @default("")
  actorName      String       @default("")
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, projectId, createdAt])
}

model Invoice {
  id                  String        @id @default(cuid())
  organizationId      String
  projectId           String
  projectNumber       String        @default("")
  projectTitle        String        @default("")
  company             String        @default("OK solutions")
  invoiceNumber       String
  status              String        @default("Entwurf")
  billingSource       String        @default("manual")
  customerName        String        @default("")
  customerStreet      String        @default("")
  customerCity        String        @default("")
  contactName         String        @default("")
  internalContactName String        @default("")
  internalPhone       String        @default("")
  internalEmail       String        @default("")
  plannedExecutionMonth String      @default("")
  introText           String        @default("")
  closingText         String        @default("")
  netTotal            Float         @default(0)
  vatRate             Float         @default(19)
  grossTotal          Float         @default(0)
  discountPercent     Float         @default(0)
  isPaid              Boolean       @default(false)
  paidAt              DateTime?
  pdfData             String?       @db.Text
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  organization        Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lines               InvoiceLine[]

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId, projectId])
}

model InvoiceLine {
  id             String             @id @default(cuid())
  organizationId String
  invoiceId      String
  catalogItemId  String             @default("")
  catalogType    String             @default("")
  position       Int                @default(0)
  quantity       Float              @default(1)
  unit           String             @default("Stk")
  title          String             @default("")
  description    String             @default("")
  unitPrice      Float              @default(0)
  discountPercent Float             @default(0)
  vatRate        Float              @default(19)
  totalNet       Float              @default(0)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice        Invoice            @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  laborItems     InvoiceLineLabor[]

  @@index([organizationId, invoiceId])
}

model InvoiceLineLabor {
  id             String       @id @default(cuid())
  organizationId String
  invoiceId      String
  invoiceLineId  String
  userId         String       @default("")
  employeeName   String       @default("")
  plannedHours   Float        @default(0)
  hourlyCostRate Float        @default(0)
  totalCost      Float        @default(0)
  position       Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoiceLine    InvoiceLine  @relation(fields: [invoiceLineId], references: [id], onDelete: Cascade)

  @@index([organizationId, invoiceId])
  @@index([organizationId, invoiceLineId])
  @@index([organizationId, userId])
}

model InvoiceHistory {
  id             String       @id @default(cuid())
  organizationId String
  invoiceId      String
  projectId      String
  invoiceNumber  String       @default("")
  eventType      String       @default("")
  title          String       @default("")
  note           String       @default("")
  actorName      String       @default("")
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, projectId, createdAt])
}

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String
  taskId         String?
  actorId        String?
  action         String
  entityType     String
  entityId       String
  payload        Json?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  task           Task?        @relation(fields: [taskId], references: [id])
}

model EscalationRule {
  id              String       @id @default(cuid())
  organizationId  String
  name            String
  hoursAfterDue   Int          @default(0)
  targetRole      Role
  isActive        Boolean      @default(true)
  emailEnabled    Boolean      @default(false)
  emailRecipients String       @default("")
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model TaskTemplate {
  id              String       @id @default(cuid())
  organizationId  String
  name            String
  description     String?
  defaultPriority TaskPriority @default(NORMAL)
  defaultEstimate Int?
  categoryId      String?
  subcategoryId   String?
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model RecurringTaskRule {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  cronExpression String
  isActive       Boolean      @default(true)
  templateId     String?
  nextRunAt      DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Absence {
  id                   String   @id
  organizationId       String
  userId               String
  requestGroupId       String?
  type                 String
  dayPart              String   @default("full")
  status               String   @default("genehmigt")
  date                 DateTime @db.Date
  representativeUserId String?
  note                 String?
  handoverTaskIds      Json     @default("[]")
  rejectionReason      String?
  history              Json     @default("[]")
  createdAt            DateTime @default(now())

  @@unique([userId, date])
}


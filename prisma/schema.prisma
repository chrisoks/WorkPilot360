generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id               String              @id @default(cuid())
  name             String
  slug             String              @unique
  locale           String              @default("de")
  timezone         String              @default("Europe/Berlin")
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  auditLogs        AuditLog[]
  categories       Category[]
  departments      Department[]
  escalationRules  EscalationRule[]
  notifications    Notification[]
  recurringRules   RecurringTaskRule[]
  subcategories    Subcategory[]
  tasks            Task[]
  taskComments     TaskComment[]
  taskLinks        TaskLink[]
  taskParticipants TaskParticipant[]
  taskTemplates    TaskTemplate[]
  teams            Team[]
  timeEntries      TimeEntry[]
  users            User[]
}

model User {
  id                  String            @id @default(cuid())
  organizationId      String
  email               String
  passwordHash        String
  firstName           String
  lastName            String
  role                Role
  isActive            Boolean           @default(true)
  teamId              String?
  departmentId        String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  dailyWorkHours      Float             @default(8)
  profileImageDataUrl String?
  salutation          String?
  birthDate           DateTime?
  language            String?
  phone               String?
  mobile              String?
  street              String?
  postalCode          String?
  city                String?
  signature           String?
  signatureHidden     Boolean?          @default(false)
  planningBoard       String?
  planningGroup       String?
  weeklyCapacity      Json              @default("{\"monday\":8,\"tuesday\":8,\"wednesday\":8,\"thursday\":8,\"friday\":8,\"saturday\":0,\"sunday\":0}")
  planningStartTime   String            @default("08:00")
  planningEndTime     String            @default("17:00")
  planningTimeWindows Json              @default("{\"monday\":{\"start\":\"08:00\",\"end\":\"17:00\"},\"tuesday\":{\"start\":\"08:00\",\"end\":\"17:00\"},\"wednesday\":{\"start\":\"08:00\",\"end\":\"17:00\"},\"thursday\":{\"start\":\"08:00\",\"end\":\"17:00\"},\"friday\":{\"start\":\"08:00\",\"end\":\"17:00\"},\"saturday\":{\"start\":\"08:00\",\"end\":\"17:00\"},\"sunday\":{\"start\":\"08:00\",\"end\":\"17:00\"}}")
  planningBreakWindows Json             @default("{\"monday\":{\"start\":\"12:00\",\"end\":\"12:30\"},\"tuesday\":{\"start\":\"12:00\",\"end\":\"12:30\"},\"wednesday\":{\"start\":\"12:00\",\"end\":\"12:30\"},\"thursday\":{\"start\":\"12:00\",\"end\":\"12:30\"},\"friday\":{\"start\":\"12:00\",\"end\":\"12:30\"},\"saturday\":{\"start\":\"\",\"end\":\"\"},\"sunday\":{\"start\":\"\",\"end\":\"\"}}")
  planningResponsibleFor Json           @default("[]")
  notifications       Notification[]
  ownedTasks          Task[]            @relation("TaskOwner")
  taskComments        TaskComment[]
  taskParticipations  TaskParticipant[]
  timeEntries         TimeEntry[]
  department          Department?       @relation(fields: [departmentId], references: [id])
  organization        Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team                Team?             @relation(fields: [teamId], references: [id])

  @@unique([organizationId, email])
}

model Department {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  teams          Team[]
  users          User[]
}

model Team {
  id             String       @id @default(cuid())
  organizationId String
  departmentId   String?
  name           String
  tasks          Task[]
  department     Department?  @relation(fields: [departmentId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users          User[]
}

model Task {
  id                      String                  @id @default(cuid())
  organizationId          String
  title                   String
  description             String
  status                  TaskStatus              @default(OFFEN)
  priority                TaskPriority            @default(NORMAL)
  deadline                DateTime
  customer                String?
  customerClass           CustomerClassification?
  categoryId              String?
  subcategoryId           String?
  estimateMinutes         Int?
  ownerId                 String
  teamId                  String?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  autoFeedbackEnabled     Boolean                 @default(false)
  autoFeedbackRecipientId String?
  recurrenceEnabled       Boolean                 @default(false)
  recurrenceInterval      String?
  recurrenceParentTaskId  String?
  createdById             String?
  acceptanceStatus        String                  @default("accepted")
  acceptanceRespondedAt   DateTime?
  rejectionReason         String?
  completedAt             DateTime?
  archiveDueAt            DateTime?
  archivedAt              DateTime?
  archiveReason           String?
  planningAllocations     Json                    @default("[]")
  auditLogs               AuditLog[]
  notifications           Notification[]
  category                Category?               @relation(fields: [categoryId], references: [id])
  organization            Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner                   User                    @relation("TaskOwner", fields: [ownerId], references: [id])
  subcategory             Subcategory?            @relation(fields: [subcategoryId], references: [id])
  team                    Team?                   @relation(fields: [teamId], references: [id])
  comments                TaskComment[]
  links                   TaskLink[]
  participants            TaskParticipant[]
  timeEntries             TimeEntry[]
}

model TaskParticipant {
  id             String       @id @default(cuid())
  organizationId String
  taskId         String
  userId         String
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  task           Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
}

model TaskComment {
  id             String       @id @default(cuid())
  organizationId String
  taskId         String
  authorId       String
  body           String
  createdAt      DateTime     @default(now())
  author         User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  task           Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model TimeEntry {
  id              String       @id @default(cuid())
  organizationId  String
  taskId          String
  userId          String
  startedAt       DateTime
  stoppedAt       DateTime?
  durationMinutes Int          @default(0)
  note            String?
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  task            Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TaskLink {
  id             String       @id @default(cuid())
  organizationId String
  taskId         String
  label          String
  url            String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  task           Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Category {
  id             String        @id @default(cuid())
  organizationId String
  name           String
  projectPrefix  String?
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subcategories  Subcategory[]
  tasks          Task[]
}

model Subcategory {
  id             String       @id @default(cuid())
  organizationId String
  categoryId     String
  name           String
  category       Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tasks          Task[]
}

model Notification {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  taskId         String?
  channel        String
  subject        String
  body           String
  linkTarget     String?
  linkTargetId   String?
  linkLabel      String?
  sentAt         DateTime?
  createdAt      DateTime     @default(now())
  readAt         DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  task           Task?        @relation(fields: [taskId], references: [id])
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String
  taskId         String?
  actorId        String?
  action         String
  entityType     String
  entityId       String
  payload        Json?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  task           Task?        @relation(fields: [taskId], references: [id])
}

model EscalationRule {
  id              String       @id @default(cuid())
  organizationId  String
  name            String
  hoursAfterDue   Int          @default(0)
  targetRole      Role
  isActive        Boolean      @default(true)
  emailEnabled    Boolean      @default(false)
  emailRecipients String       @default("")
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model TaskTemplate {
  id              String       @id @default(cuid())
  organizationId  String
  name            String
  description     String?
  defaultPriority TaskPriority @default(NORMAL)
  defaultEstimate Int?
  categoryId      String?
  subcategoryId   String?
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model RecurringTaskRule {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  cronExpression String
  isActive       Boolean      @default(true)
  templateId     String?
  nextRunAt      DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Absence {
  id                   String   @id
  organizationId       String
  userId               String
  type                 String
  date                 DateTime @db.Date
  note                 String?
  createdAt            DateTime @default(now())
  representativeUserId String?

  @@unique([userId, date])
}

model Contact {
  id                    String   @id
  organizationId        String
  category              String   @default("Kunde")
  type                  String   @default("person")
  customerNumber        String
  salutation            String?
  additionalSalutation  String?
  companyName           String?
  firstName             String?
  lastName              String?
  position              String?
  email                 String?
  phone                 String?
  mobile                String?
  fax                   String?
  website               String?
  source                String?
  reachability          String?
  isInvoiceRecipient    Boolean  @default(false)
  street                String?
  addressLine1          String?
  addressLine2          String?
  postalCode            String?
  city                  String?
  country               String?
  paymentTermDays       Int?
  discountPercent       Float?
  discountTermDays      Int?
  priceGroup            String?
  iban                  String?
  bic                   String?
  bankName              String?
  taxId                 String?
  debtorCreditorAccount String?
  leitwegId             String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @default(now())
  parentCompanyId       String?
  parentCompanyName     String?
  mainContactName       String?
  isMainContact         Boolean  @default(false)
  legalForm             String?
}

model DocumentTextTemplate {
  id             String   @id
  organizationId String
  source         String   @default("Eigene")
  kind           String   @default("text")
  title          String
  body           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now())

  @@unique([organizationId, title], map: "DocumentTextTemplate_org_title_key")
}

model DocumentTypeConfig {
  id             String    @id
  organizationId String
  name           String
  baseType       String    @default("Dokument")
  folder         String    @default("Allgemein")
  status         String    @default("Aktiv")
  config         Json      @default("{}")
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now())

  @@unique([organizationId, name], map: "DocumentTypeConfig_org_name_key")
}

model ProjectLogbookEntry {
  id             String   @id
  organizationId String
  projectId      String
  title          String?
  body           String
  author         String?
  colleague      String?
  visibleFor     Json     @default("[]")
  attachments    Json     @default("[]")
  createdAt      DateTime @default(now())
}

model ProjectTimeEntry {
  id             String   @id
  organizationId String
  projectId      String
  projectLabel   String?
  employee       String?
  date           String
  startTime      String
  endTime        String
  durationMs     BigInt   @default(0)
  pauseMs        BigInt   @default(0)
  comment        String?
  createdAt      DateTime @default(now())
  mode           String   @default("project")
}

model PlanningEntry {
  id                   String   @id
  organizationId       String
  source               String   @default("manual")
  board                String
  groupName            String
  userId               String?
  employeeName         String?
  date                 String
  startTime            String
  endTime              String
  durationMinutes      Int      @default(0)
  title                String
  description          String?
  customer             String?
  projectId            String?
  projectLabel         String?
  offerId              String?
  offerLineId          String?
  offerLabel           String?
  offerTotalMinutes    Int?
  offerPlannedMinutes  Int?
  approvalStatus       String   @default("confirmed")
  requestedByUserId    String?
  requestedByName      String?
  approvedByUserId     String?
  approvedAt           DateTime?
  deletedAt            DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @default(now())
}

model PlanningEntryHistory {
  id              String   @id
  organizationId  String
  planningEntryId String
  projectId       String?
  eventType       String
  actorUserId     String?
  actorName       String?
  fromStatus      String?
  toStatus        String?
  note            String?
  createdAt       DateTime @default(now())
}

model UserTeamMembership {
  userId    String
  teamId    String
  createdAt DateTime @default(now())

  @@id([userId, teamId])
}

model WorkPilotProject {
  id                  String   @id
  organizationId      String
  projectNumber       String
  title               String
  customer            String?
  status              String   @default("Lead / Kl├ñrung")
  statusCode          String?
  description         String?
  contactId           String?
  contactPersonId     String?
  addressContactId    String?
  projectType         String?
  projectKind         String?
  projectRuntimeFrom  String?
  projectRuntimeUntil String?
  billingInterval     String?
  trade               String?
  branch              String?
  volume              String?
  source              String?
  address             String?
  participants        String?
  timeBudgetHours     String?
  timeBudgetHistory   Json     @default("[]")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @default(now())
  responsibleName     String?
}

enum Role {
  ADMIN
  GESCHAEFTSFUEHRER
  FUEHRUNGSKRAFT
  MITARBEITER
  GAST
}

enum TaskStatus {
  OFFEN
  IN_BEARBEITUNG
  WARTET_AUF_RUECKMELDUNG
  ERLEDIGT
  ABGELEHNT
  UEBERFAELLIG
  ARCHIVIERT
}

enum TaskPriority {
  NIEDRIG
  NORMAL
  HOCH
  KRITISCH
}

enum CustomerClassification {
  A
  B
  C
}
